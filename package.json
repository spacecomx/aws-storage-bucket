{
  "name": "@spacecomx/aws-storage-bucket",
  "version": "0.1.0",
  "packageManager": "pnpm@10.11.0",
  "description": "AWS S3 bucket management for storage of media, document and log files.",
  "author": "Spacecomx, LLC",
  "license": "MIT",
  "main": "dist/bin/index.js",
  "types": "dist/bin/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spacecomx/aws-storage-bucket.git"
  },
  "keywords": [
    "aws",
    "s3",
    "bucket",
    "storage",
    "media",
    "documents",
    "logs",
    "cdk"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "clean": "rimraf dist && rimraf cdk.out",
    "clean:all": "pnpm clean && rimraf pnpm-lock.yaml node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@types/jest": "^30.0.0",
    "@types/node": "22.16.0",
    "aws-cdk": "2.1108.0",
    "cdk-nag": "^2.30.0",
    "eslint": "^9.37.0",
    "jest": "^30.2.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.46.1",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "aws-cdk-lib": "2.240.0",
    "constructs": "^10.5.1"
  }
}
